<?xml version="1.0" encoding="UTF-8"?>
<site xmlns="urn:enonic:xp:model:1.0">
  <x-data name="system:menu-item"/>
  <x-data name="myapplication:my-meta-mixin"/>
  <form>
    <input type="TextLine" name="some-name">
      <label>Textline</label>
      <immutable>false</immutable>
      <indexed>false</indexed>
      <custom-text/>
      <help-text/>
      <occurrences minimum="0" maximum="1"/>
    </input>
  </form>
  <processors>
    <response-processor name="filter1" order="10"/>
    <response-processor name="filter2" order="20"/>
  </processors>
  <mappings>
    <mapping controller="/folder/controllers/preview.js" order="50">
      <match>type:'.*:person|.*:movie|.*:folder'</match>
    </mapping>
    <mapping controller="/site/mappings/controller.js">
      <pattern>/controller</pattern>
    </mapping>
    <mapping filter="/site/mappings/filter1.js">
      <pattern>/filter1</pattern>
    </mapping>
  </mappings>
</site>
